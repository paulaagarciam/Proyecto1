                                 .include "M328PDEF.inc"     // Include definitions specific to ATMega328P
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 .equ t1 = 0xC2F7
                                 .equ modes = 5
                                 .def segs = R18
                                 .def mins_unidades = R19
                                 .def mins_decenas = R20
                                 .def hrs_unidades = R21
                                 .def hrs_decenas = R22
                                 .def dia_unidades = R23
                                 .def dia_decenas = R24
                                 .def mes_unidades = R25
                                 .def mes_decenas = R26
                                 .dseg
000100                           digito: .byte 1
000101                           mode: .byte 1
000102                           alarma_mins_decenas: .byte 1
000103                           alarma_mins_unidades: .byte 1
000104                           alarma_hrs_decenas: .byte 1
000105                           alarma_hrs_unidades: .byte 1
000106                           alarma_flag: .byte 1
000107                           parpadeo_dp: .byte 1
                                 .org    SRAM_START
                                 //variable_name:     .byte   1   // Memory alocation for variable_name:     .byte   (byte size)
                                 
                                 .cseg
                                 .org 0x0000
000000 c021                      RJMP START
                                 
                                 .org PCI1addr
000008 940c 0089                 JMP ISR_BOTONES
                                 
                                 .org OVF1addr
00001a 940c 0230                 JMP ISR_TIMER1
                                 
                                 .org OVF0addr
000020 940c 02ca                 JMP IRS_TIMER0
                                 
                                  /**************/
                                 // Configuración de la pila
                                 
                                 START:
000022 94f8                      CLI
                                 
000023 ef0f                      LDI     R16, LOW(RAMEND)
000024 bf0d                      OUT     SPL, R16
000025 e008                      LDI     R16, HIGH(RAMEND)
000026 bf0e                      OUT     SPH, R16
                                 
                                 /**************/
                                 // Configuracion MCU
                                 SETUP:
                                 
                                 ; ======================================
                                 ; CONFIGURAR OSCILADOR A 1MHZ
                                 ; ======================================
000027 e800                      LDI R16, (1<<CLKPCE)						; Habilito la posibilidad de cambiar el oscilador
000028 9300 0061                 STS CLKPR, R16								; aquí escribo el valor en el registro CLKPR
                                 
00002a e004                      LDI R16, 0b0000_0100						; Configuro el prescaler a 16 (16MHz/16 = 1MHz)
00002b 9300 0061                 STS CLKPR, R16								; Escribo ese valor en el registro CLKPR y con eso ya cambié el oscilador.
                                 // 
                                 
                                 
                                 ; ======================================
                                 ; USAR PD0 Y PD1
                                 ; ======================================
00002d e000                      LDI R16, 0x00
00002e 9300 00c1                 STS UCSR0B, R16
                                 
                                 ; ======================================
                                 ; CONFIGURAR PORTB
                                 ; ======================================
                                 								 
000030 ef0f                      LDI R16, 0b11111111									; Configuro pullUp y leds apagadas
000031 b904                      OUT DDRB, R16
000032 e100                      LDI R16, 0b00010000									; Configuro Entradas y salidas
000033 b905                      OUT PORTB, R16
                                 
                                 ; ======================================
                                 ; CONFIGURAR PORTC
                                 ; ======================================
                                 
000034 e10f                      LDI R16, 0b00011111									; Configuro Entradas y salidas
000035 b908                      OUT PORTC, R16								 
000036 e200                      LDI R16, 0b00100000								; Configuro pullUp y leds apagadas
000037 b907                      OUT DDRC, R16
                                 
                                 ; ======================================
                                 ; CONFIGURAR PORTD
                                 ; ======================================
                                 								 
000038 ef0f                      LDI R16, 0xFF								; Configuro pullUp y leds apagadas
000039 b90a                      OUT DDRD, R16
00003a e000                      LDI R16, 0x00									; Configuro Entradas y salidas
00003b b90b                      OUT PORTD, R16
                                 
                                 
                                 //interrupciones:
                                 
                                 ; ======================================
                                 ; CONFIGURAR TCNT0
                                 ; ======================================
00003c e001                      LDI R16, (1<<TOIE0)							; habilito interrupción del overflow
00003d 9300 006e                 STS TIMSK0, R16
                                 
                                 ; ======================================
                                 ; CONFIGURAR TCNT1
                                 ; ======================================
00003f e001                      LDI R16, (1<<TOIE1)							; habilito interrupción del overflow para timer 1
000040 9300 006f                 STS TIMSK1, R16
                                 
                                 ; ======================================
                                 ; CONFIGURAR PIN CHANGE 
                                 ; ======================================
000042 e002                      LDI R16,(1<<PCIE1)
000043 9300 0068                 STS PCICR,R16
                                 
000045 e10f                      LDI R16,(1<<PCINT9)|(1<<PCINT10)|(1<<PCINT11) |(1<<PCINT12) |(1<<PCINT8)
000046 9300 006c                 STS PCMSK1,R16
                                 
                                 ; ======================================
                                 ; CONFIGURAR TIMER0
                                 ; ======================================
                                 
000048 e000                      LDI R16, 0x00
000049 bd04                      OUT TCCR0A, R16
                                 
00004a e002                      LDI R16, (1<<CS01)				; prescaler 64
00004b bd05                      OUT TCCR0B, R16
                                 
00004c e001                      LDI R16, (1<<TOV0)							; limpiar bandera overflow
00004d bb05                      OUT TIFR0, R16
                                 
                                 ; ======================================
                                 ; CONFIGURAR TIMER1
                                 ; ======================================
                                 
00004e e000                      LDI R16, 0x00
00004f 9300 0080                 STS TCCR1A, R16
                                 
000051 e003                      LDI R16, (1<<CS11)|(1<<CS10)				; prescaler 64
000052 9300 0081                 STS TCCR1B, R16
                                 
000054 e001                      LDI R16, (1<<TOV0)							; limpiar bandera overflow
000055 bb05                      OUT TIFR0, R16
                                 
000056 ec02                      LDI R16, HIGH(t1)							;asigno valor del TCNT del prescaler 
000057 9300 0085                 STS TCNT1H, R16
000059 ef07                      LDI R16, LOW(t1)
00005a 9300 0084                 STS TCNT1L, R16
                                 
                                 ; ======================================
                                 ; CONFIGURAR TABLAS DE 7 SEGMENTOS
                                 ; ======================================
                                 Table7seg:
00005c 063f
00005d 4f5b
00005e 6d66
00005f 077d
000060 6f7f                      	.db 0x3F,0x06,0x5B,0x4F,0x66,0x6D,0x7D,0x07,0x7F,0x6F
                                 
000061 e000                      LDI R16, 0
000062 9300 0101                 STS mode, R16
000064 9300 0100                 STS digito, R16
000066 9300 0102                 STS alarma_mins_decenas, R16
000068 9300 0103                 STS alarma_mins_unidades, R16
00006a 9300 0104                 STS alarma_hrs_decenas, R16
00006c 9300 0105                 STS alarma_hrs_unidades, R16
00006e 9300 0106                 STS alarma_flag, R16
000070 e001                      LDI R16, 1
000071 9300 0107                 STS parpadeo_dp, R16
000073 2700                      CLR R16
000074 2744                      CLR R20									   ;
000075 2755                      CLR R21									   ;
000076 2766                      CLR R22									   ;
000077 2777                      CLR R23									   ;
000078 2788                      CLR R24									   ;
000079 2799                      CLR R25									   ;
00007a 27aa                      CLR R26									   ;
00007b 2711                      CLR R17									   ;
00007c 2722                      CLR R18									   ;									   ;
00007d 2733                      CLR R19									   ;
00007e 2722                      CLR R18									   ;
00007f e039                      LDI mins_unidades, 9
000080 e045                      LDI mins_decenas, 5
000081 e053                      LDI hrs_unidades, 3
000082 e062                      LDI hrs_decenas, 2
000083 e092                      LDI mes_unidades, 2
000084 e0a1                      LDI mes_decenas, 1
000085 e071                      LDI dia_unidades, 1
000086 e083                      LDI dia_decenas, 3
                                 
                                 // INTERRUPCIONES GLOBALES
000087 9478                      SEI
                                 /**************/
                                 // Loop Infinito
                                 MAIN_LOOP:
000088 cfff                          RJMP    MAIN_LOOP
                                 
                                 /**************/
                                 // NON-Interrupt subroutines
                                 
                                 /**************/
                                 // Interrupt routines
                                 ISR_BOTONES:
000089 930f                      	PUSH R16
00008a 931f                      	PUSH R17
00008b 93bf                      	PUSH R27
00008c 93cf                      	PUSH R28
00008d b70f                      	IN R16, SREG
00008e 930f                      	PUSH R16
                                 	
00008f 9930                      	SBIC PINC, PINC0			;verifico si boton modo fue presionado
000090 c015                      	RJMP BOTONES_INC_O_DEC
000091 9100 0106                 	LDS R16, alarma_flag
000093 3001                      	CPI R16, 0x01				;si alarma esta prendida la apaga
000094 f429                      	BRNE MODO
000095 9845                      	CBI PORTC, PORTC5
000096 e000                      	LDI R16, 0x00
000097 9300 0106                 	STS alarma_flag, R16		;APAGO ALARMA
000099 c18f                      	RJMP FIN_ISR_BOTONES
                                 
                                 	MODO:
00009a 9100 0101                 	LDS R16, mode
00009c 9503                      	INC R16						;AUMENTO MODO
00009d 3005                      	CPI R16, modes				;VERIFICO OVERFLOW MODOS
00009e f421                      	BRNE NO_OVERFLOW_MODOS
00009f 2700                      	CLR R16						;REINICIO MODO
0000a0 9300 0101                 	STS mode, R16	
0000a2 c186                      	RJMP FIN_ISR_BOTONES
                                 
                                 	NO_OVERFLOW_MODOS:
0000a3 9300 0101                 	STS mode, R16				;GUARDO NUEVO VALOR DE MODO
0000a5 c183                      	RJMP FIN_ISR_BOTONES
                                 	
                                 
                                 	BOTONES_INC_O_DEC:
0000a6 9100 0101                 	LDS R16, mode
0000a8 3000                      	CPI R16, 0				;SI ESTA EN MODO MOSTRAR HORA BOTONES PC1-PC4 NO HACEN NADA
0000a9 f419                      	BRNE NO_MODO_HORA
0000aa 9a2c                      	SBI PORTB, 4
0000ab 982d                      	CBI PORTB, 5
0000ac c17c                      	RJMP FIN_ISR_BOTONES
                                 	NO_MODO_HORA:
0000ad 3002                      	CPI R16, 2				;SI ESTA EN MODO FECHA HORA BOTONES PC1-PC4 NO HACEN NADA
0000ae f419                      	BRNE NO_MODO_FECHA
0000af 9a2d                      	SBI PORTB, 5
0000b0 982c                      	CBI PORTB, 4
0000b1 c177                      	RJMP FIN_ISR_BOTONES
                                 	NO_MODO_FECHA:
0000b2 3001                      	CPI R16, 1
0000b3 f021                      	BREQ CONFIG_HORA		;MODO CONFIGURAR HORA, REVISA BOTONES
0000b4 3003                      	CPI R16, 3
0000b5 f409                      	BRNE NO_CONFIG_FECHA
0000b6 c053                      	RJMP CONFIG_FECHA
                                 	NO_CONFIG_FECHA:		;MODO CONFIG FECHA, REVISA BOTONES
0000b7 c0cb                      	RJMP CONFIG_ALARMA		;MODO CONFIG ALARMA, REVISA BOTONES
                                 		
                                 		//CONFIGURACION HORA
                                 		CONFIG_HORA:
0000b8 9931                      		SBIC PINC, PINC1
0000b9 c001                      		RJMP REVISA_INC_HORAS
                                 		; HORAS --
0000ba c009                      		RJMP DEC_HORAS
                                 
                                 		REVISA_INC_HORAS:
0000bb 9932                      		SBIC PINC, PINC2
0000bc c001                      		RJMP REVISA_DEC_MINS
                                 		; HORAS ++
0000bd c01b                      		RJMP INC_HORAS
                                 
                                 		REVISA_DEC_MINS:
0000be 9933                      		SBIC PINC, PINC3
0000bf c001                      		RJMP REVISA_INC_MINS
                                 		; MINUTOS --
0000c0 c02d                      		RJMP DEC_MINS
                                 
                                 		REVISA_INC_MINS:
0000c1 9934                      		SBIC PINC, PINC4
0000c2 c166                      		RJMP FIN_ISR_BOTONES
                                 		; MINUTOS ++
0000c3 c038                      		RJMP INC_MINS
                                 			
                                 			//BOTON DEC IZQUIERDA PD1
                                 			DEC_HORAS:
0000c4 3060                      			CPI hrs_decenas, 0
0000c5 f429                      			BRNE DEC_HORAS_NORMAL
0000c6 3050                      			CPI hrs_unidades, 0
0000c7 f419                      			BRNE DEC_HORAS_NORMAL
                                 
0000c8 e062                      			LDI hrs_decenas, 2
0000c9 e053                      			LDI hrs_unidades, 3
0000ca c15e                      			RJMP FIN_ISR_BOTONES
                                 
                                 			DEC_HORAS_NORMAL:
0000cb 2355                      			TST hrs_unidades
0000cc f451                      			BRNE SOLO_DEC_UNIDADES_H
0000cd e059                      			LDI hrs_unidades, 9
0000ce 956a                      			DEC hrs_decenas
0000cf 3062                      			CPI hrs_decenas, 2
0000d0 f009                      			BREQ SIGUE_1
0000d1 c157                      			RJMP FIN_ISR_BOTONES
                                 			SIGUE_1:
0000d2 3059                      			CPI hrs_unidades, 9
0000d3 f009                      			BREQ SIGUE_2
0000d4 c154                      			RJMP FIN_ISR_BOTONES
                                 			SIGUE_2:
                                 			; evita 29, debe ser 23
0000d5 e053                      			LDI hrs_unidades, 3
0000d6 c152                      			RJMP FIN_ISR_BOTONES
                                 
                                 			SOLO_DEC_UNIDADES_H:
0000d7 955a                      			DEC hrs_unidades
0000d8 c150                      			RJMP FIN_ISR_BOTONES
                                 
                                 			//BOTON INC IZQUIERDA PD2
                                 			INC_HORAS:
0000d9 3062                      			CPI hrs_decenas, 2
0000da f429                      			BRNE INC_HORAS_NORMAL
0000db 3053                      			CPI hrs_unidades, 3
0000dc f419                      			BRNE INC_HORAS_NORMAL
                                 
0000dd 2766                      			CLR hrs_decenas
0000de 2755                      			CLR hrs_unidades
0000df c149                      			RJMP FIN_ISR_BOTONES
                                 
                                 			INC_HORAS_NORMAL:
0000e0 9553                      			INC hrs_unidades
0000e1 305a                      			CPI hrs_unidades, 10
0000e2 f411                      			BRNE AJUSTE_24H
                                 
0000e3 2755                      			CLR hrs_unidades
0000e4 9563                      			INC hrs_decenas
                                 
                                 			AJUSTE_24H:
0000e5 3062                      			CPI hrs_decenas, 2
0000e6 f009                      			BREQ SIGUE_3
0000e7 c141                      			RJMP FIN_ISR_BOTONES
                                 			SIGUE_3:
0000e8 3054                      			CPI hrs_unidades, 4
0000e9 f009                      			BREQ SIGUE_4
0000ea c13e                      			RJMP FIN_ISR_BOTONES
                                 			SIGUE_4:
                                 
0000eb 2766                      			CLR hrs_decenas
0000ec 2755                      			CLR hrs_unidades
0000ed c13b                      			RJMP FIN_ISR_BOTONES
                                 
                                 			//BOTON DEC DERECHA PD3
                                 			DEC_MINS:
0000ee 3040                      			CPI mins_decenas, 0
0000ef f429                      			BRNE DEC_MINS_NORMAL
0000f0 3030                      			CPI mins_unidades, 0
0000f1 f419                      			BRNE DEC_MINS_NORMAL
                                 
0000f2 e045                      			LDI mins_decenas, 5
0000f3 e039                      			LDI mins_unidades, 9
0000f4 c134                      			RJMP FIN_ISR_BOTONES
                                 
                                 			DEC_MINS_NORMAL:
0000f5 2333                      			TST mins_unidades
0000f6 f419                      			BRNE SOLO_DEC_UNIDADES_M
                                 
0000f7 e039                      			LDI mins_unidades, 9
0000f8 954a                      			DEC mins_decenas
0000f9 c12f                      			RJMP FIN_ISR_BOTONES
                                 
                                 			SOLO_DEC_UNIDADES_M:
0000fa 953a                      			DEC mins_unidades
0000fb c12d                      			RJMP FIN_ISR_BOTONES
                                 
                                 			//BOTON INC DERECHA PD4
                                 			INC_MINS:
0000fc 3045                      			CPI mins_decenas, 5
0000fd f429                      			BRNE INC_MINS_NORMAL
0000fe 3039                      			CPI mins_unidades, 9
0000ff f419                      			BRNE INC_MINS_NORMAL
                                 
000100 2744                      			CLR mins_decenas
000101 2733                      			CLR mins_unidades
000102 c126                      			RJMP FIN_ISR_BOTONES
                                 
                                 			INC_MINS_NORMAL:
000103 9533                      			INC mins_unidades
000104 303a                      			CPI mins_unidades, 10
000105 f009                      			BREQ SIGUE_5
000106 c122                      			RJMP FIN_ISR_BOTONES
                                 			SIGUE_5:
                                 
000107 2733                      			CLR mins_unidades
000108 9543                      			INC mins_decenas
000109 c11f                      			RJMP FIN_ISR_BOTONES
                                 		
                                 		//CONFIGURACION FECHA
                                 		CONFIG_FECHA:
00010a 9931                      		SBIC PINC, PINC1
00010b c001                      		RJMP REVISA_INC_DIA
00010c c009                      		RJMP DEC_DIA
                                 
                                 		REVISA_INC_DIA:
00010d 9932                      		SBIC PINC, PINC2
00010e c001                      		RJMP REVISA_DEC_MES
00010f c015                      		RJMP INC_DIA
                                 
                                 		REVISA_DEC_MES:
000110 9933                      		SBIC PINC, PINC3
000111 c001                      		RJMP REVISA_INC_MES
000112 c021                      		RJMP DEC_MES
                                 
                                 		REVISA_INC_MES:
000113 9934                      		SBIC PINC, PINC4
000114 c114                      		RJMP FIN_ISR_BOTONES
000115 c031                      		RJMP INC_MES
                                 
                                 			//BOTON DEC IZQUIERDA PD1
                                 			DEC_DIA:
000116 3080                      			CPI dia_decenas, 0
000117 f431                      			BRNE DEC_DIA_NORMAL
000118 3071                      			CPI dia_unidades, 1
000119 f421                      			BRNE DEC_DIA_NORMAL
00011a d03f                      			RCALL GET_MAX_DIA_MES
00011b 2f8b                      			MOV dia_decenas, R27
00011c 2f7c                      			MOV dia_unidades, R28
00011d c10b                      			RJMP FIN_ISR_BOTONES
                                 
                                 			DEC_DIA_NORMAL:
00011e 2377                      			TST dia_unidades
00011f f419                      			BRNE SOLO_DEC_DIA_UNIDADES
000120 e079                      			LDI dia_unidades, 9
000121 958a                      			DEC dia_decenas
000122 c106                      			RJMP FIN_ISR_BOTONES
                                 
                                 			SOLO_DEC_DIA_UNIDADES:
000123 957a                      			DEC dia_unidades
000124 c104                      			RJMP FIN_ISR_BOTONES
                                 
                                 			//BOTON INC IZQUIERDA PD2
                                 			INC_DIA:
000125 d034                      			RCALL GET_MAX_DIA_MES
                                 			; si dia == maximo, volver a 01
000126 178b                      			CP dia_decenas, R27
000127 f429                      			BRNE INC_DIA_NORMAL
000128 177c                      			CP dia_unidades, R28
000129 f419                      			BRNE INC_DIA_NORMAL
00012a 2788                      			CLR dia_decenas
00012b e071                      			LDI dia_unidades, 1
00012c c0fc                      			RJMP FIN_ISR_BOTONES
                                 
                                 			INC_DIA_NORMAL:
00012d 9573                      			INC dia_unidades
00012e 307a                      			CPI dia_unidades, 10
